#!/usr/bin/env python3
# @file ~/.local/bin/populate-secrets
# @brief Scan every plausible secret source on the box and write age-encrypted
#        chezmoi-secret files for anything new.
# @description
#   Sources scanned (each is optional — missing source = skip silently):
#     1. Current process environment for ~50 known secret-shaped env vars
#     2. `gh auth token` — GitHub CLI's OAuth token
#     3. `atuin key` — atuin sync key
#     4. macOS Keychain — Claude Code credentials, Warp token, etc.
#     5. `~/.aws/credentials` — AWS access keys (default profile)
#     6. `~/.npmrc` — registry _authToken
#
#   Output:
#     ~/.local/share/chezmoi/home/.chezmoitemplates/secrets/<NAME>
#       contains the age-encrypted value, ready for chezmoi templating.
#
#   Idempotent: anything already encrypted is skipped (no clobber).
#   Run after fresh-machine provisioning to bring credentials into chezmoi.

import os
import pathlib
import platform
import subprocess
import sys

SECRETS_DIR = pathlib.Path.home() / ".local/share/chezmoi/home/.chezmoitemplates/secrets"
HEYRED = "\033[31m"
GREEN = "\033[32m"
DIM = "\033[2m"
RESET = "\033[0m"


def log(level: str, msg: str) -> None:
    icon = {"info": "▶", "ok": "✔", "skip": "·", "warn": "◆", "err": "✗"}.get(level, " ")
    color = {"ok": GREEN, "err": HEYRED, "skip": DIM}.get(level, "")
    print(f"  {color}{icon} {msg}{RESET}", file=sys.stderr)


def ensure_dir() -> None:
    if not SECRETS_DIR.is_dir():
        log("err", f"secrets dir missing: {SECRETS_DIR}")
        log("err", "is chezmoi cloned to ~/.local/share/chezmoi?")
        sys.exit(1)


def existing_names() -> set[str]:
    return {p.name for p in SECRETS_DIR.iterdir() if p.is_file()}


def encrypt(name: str, value: str, have: set[str]) -> str:
    if not value or not value.strip():
        return "empty"
    if name in have:
        return "exists"
    try:
        proc = subprocess.run(
            ["chezmoi", "encrypt"],
            input=value.encode(),
            capture_output=True,
            check=True,
            timeout=10,
        )
        (SECRETS_DIR / name).write_bytes(proc.stdout)
        have.add(name)
        return "wrote"
    except subprocess.CalledProcessError as exc:
        log("err", f"{name}: {exc.stderr.decode()[:120]}")
        return "err"


# Known env-var names where a real secret is likely to be present.
ENV_CANDIDATES = [
    "EMDASH_HOOK_TOKEN", "JFS_PRIVATE_KEY", "WAKATIME_API_KEY",
    "NPM_TOKEN", "NODE_AUTH_TOKEN", "GITLAB_TOKEN", "BITBUCKET_TOKEN",
    "FLY_API_TOKEN", "VERCEL_TOKEN", "NETLIFY_AUTH_TOKEN",
    "DIGITALOCEAN_TOKEN", "LINODE_TOKEN", "HETZNER_TOKEN",
    "TAILSCALE_AUTHKEY", "PUSHOVER_TOKEN", "NTFY_TOKEN",
    "NGROK_AUTHTOKEN", "CLOUDFLARE_ZONE_ID",
    "TURSO_AUTH_TOKEN", "NEON_API_KEY", "PLANETSCALE_TOKEN",
    "RAILWAY_TOKEN", "RENDER_API_KEY", "SUPABASE_ACCESS_TOKEN",
    "CONVEX_DEPLOY_KEY", "CLERK_SECRET_KEY", "CLERK_PUBLISHABLE_KEY",
    "AUTH0_DOMAIN", "AUTH0_CLIENT_ID", "AUTH0_CLIENT_SECRET",
    "OPENROUTER_API_KEY", "PERPLEXITY_API_KEY", "TOGETHER_API_KEY",
    "GROQ_API_KEY", "MISTRAL_API_KEY", "COHERE_API_KEY",
    "REPLICATE_API_TOKEN", "HUGGINGFACE_TOKEN", "HF_TOKEN",
    "POSTHOG_PROJECT_API_KEY", "AMPLITUDE_API_KEY", "MIXPANEL_TOKEN",
    "SLACK_BOT_TOKEN", "SLACK_WEBHOOK_URL", "TELEGRAM_BOT_TOKEN",
    "TWILIO_ACCOUNT_SID", "TWILIO_AUTH_TOKEN",
    "NOTION_API_KEY", "LINEAR_API_KEY", "AIRTABLE_API_KEY",
    "FIRECRAWL_API_KEY", "BROWSERLESS_TOKEN", "SCRAPER_API_KEY",
    "COMPOSIO_API_KEY", "BRAVE_API_KEY",
]


def from_env(have: set[str]) -> dict[str, int]:
    counts = {"wrote": 0, "exists": 0, "empty": 0, "err": 0}
    for name in ENV_CANDIDATES:
        value = os.environ.get(name, "")
        result = encrypt(name, value, have)
        counts[result] += 1
        if result == "wrote":
            log("ok", name)
    return counts


def from_gh(have: set[str]) -> dict[str, int]:
    counts = {"wrote": 0, "exists": 0, "empty": 0, "err": 0}
    try:
        r = subprocess.run(
            ["gh", "auth", "token"], capture_output=True, text=True, timeout=5
        )
        if r.returncode == 0:
            result = encrypt("GH_AUTH_TOKEN", r.stdout.strip(), have)
            counts[result] += 1
            if result == "wrote":
                log("ok", "GH_AUTH_TOKEN (from gh CLI)")
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return counts


def from_atuin(have: set[str]) -> dict[str, int]:
    counts = {"wrote": 0, "exists": 0, "empty": 0, "err": 0}
    try:
        r = subprocess.run(
            ["atuin", "key"], capture_output=True, text=True, timeout=5
        )
        if r.returncode == 0:
            result = encrypt("ATUIN_SYNC_KEY", r.stdout.strip(), have)
            counts[result] += 1
            if result == "wrote":
                log("ok", "ATUIN_SYNC_KEY (from atuin)")
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return counts


KEYCHAIN_CANDIDATES = [
    # (keychain service, target chezmoi-secret name, account-filter or None)
    ("Claude Code-credentials", "CLAUDE_CODE_CREDENTIALS_JSON", None),
    ("dev.warp.Warp-Stable", "WARP_KEYCHAIN_TOKEN", None),
]


def from_keychain(have: set[str]) -> dict[str, int]:
    counts = {"wrote": 0, "exists": 0, "empty": 0, "err": 0}
    if platform.system() != "Darwin":
        return counts
    for service, name, account in KEYCHAIN_CANDIDATES:
        cmd = ["security", "find-generic-password", "-s", service, "-w"]
        if account:
            cmd[3:3] = ["-a", account]
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
            if r.returncode == 0:
                result = encrypt(name, r.stdout.strip(), have)
                counts[result] += 1
                if result == "wrote":
                    log("ok", f"{name} (from Keychain '{service}')")
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass
    return counts


def from_aws(have: set[str]) -> dict[str, int]:
    counts = {"wrote": 0, "exists": 0, "empty": 0, "err": 0}
    creds = pathlib.Path.home() / ".aws/credentials"
    if not creds.is_file():
        return counts
    section, parsed = None, {}
    for line in creds.read_text().splitlines():
        line = line.strip()
        if line.startswith("[") and line.endswith("]"):
            section = line[1:-1].strip()
            parsed.setdefault(section, {})
        elif "=" in line and section:
            k, _, v = line.partition("=")
            parsed[section][k.strip()] = v.strip()
    default = parsed.get("default", {})
    for k_aws, k_target in [
        ("aws_access_key_id", "AWS_ACCESS_KEY_ID_FROM_FILE"),
        ("aws_secret_access_key", "AWS_SECRET_ACCESS_KEY_FROM_FILE"),
    ]:
        if k_aws in default:
            result = encrypt(k_target, default[k_aws], have)
            counts[result] += 1
            if result == "wrote":
                log("ok", f"{k_target} (from ~/.aws/credentials)")
    return counts


def from_npmrc(have: set[str]) -> dict[str, int]:
    counts = {"wrote": 0, "exists": 0, "empty": 0, "err": 0}
    npmrc = pathlib.Path.home() / ".npmrc"
    if not npmrc.is_file():
        return counts
    for line in npmrc.read_text().splitlines():
        if "_authToken=" in line:
            tok = line.split("_authToken=", 1)[1].strip()
            result = encrypt("NPM_AUTH_TOKEN", tok, have)
            counts[result] += 1
            if result == "wrote":
                log("ok", "NPM_AUTH_TOKEN (from ~/.npmrc)")
            break
    return counts


def main() -> int:
    ensure_dir()
    have = existing_names()
    log("info", f"{len(have)} secrets already encrypted at {SECRETS_DIR}")

    totals = {"wrote": 0, "exists": 0, "empty": 0, "err": 0}
    for source in (from_env, from_gh, from_atuin, from_keychain, from_aws, from_npmrc):
        for k, v in source(have).items():
            totals[k] += v

    log("info", f"wrote {totals['wrote']} new · {totals['exists']} already-encrypted · "
                 f"{totals['empty']} not-in-env · {totals['err']} errors")
    return 0


if __name__ == "__main__":
    sys.exit(main())
