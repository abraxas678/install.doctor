# shellcheck disable=SC1090,SC1091,SC2034,SC2154,SC2296

###############################################################################
# install.doctor — zsh startup
#
# Architecture:
#   1. p10k instant-prompt (cached precomputed prompt; renders in <50ms)
#   2. Minimal pre-prompt block: history, key bindings, FPATH
#   3. powerlevel10k theme (synchronous — it IS the prompt)
#   4. zinit turbo mode for every other plugin (loaded 0ms AFTER first prompt)
#   5. Lazy stubs for eval-init tools (mise, atuin, direnv, navi, …)
#
# Cold-start target: <0.20s. Warm-start target: <0.10s. Benchmark with
#   for i in 1 2 3 4 5; do /usr/bin/time -p zsh -i -c exit 2>&1 | grep real; done
#
# Re-source after edits: `exec zsh` (forces zcompile rebuild on next launch).
###############################################################################

### Language / Fonts
export LANG="en_US"
export LC_ALL="en_US.UTF-8"

### Advanced Bash-features are supported
export BASH_SUPPORT=true

### Import Common Settings
export SHOW_MOTD=false
[ ! -f "${XDG_CONFIG_HOME:-$HOME/.config}/shell/profile.sh" ] || source "${XDG_CONFIG_HOME:-$HOME/.config}/shell/profile.sh"

### Escape if root or non-interactive — root shells skip everything below
### (provisioning runs as root and the heavy plugin stack would just slow
### it down for no benefit).
if [ "$USER" = 'root' ]; then
  return
fi
case $- in
  *i*) ;;
    *) return;;
esac

### XDG-compliant history file
[ -d "${XDG_STATE_HOME:-$HOME/.local/state}/zsh" ] || mkdir -p "${XDG_STATE_HOME:-$HOME/.local/state}/zsh"
export HISTFILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"

# ============================================================================
# Debug + safety harness — every potentially-slow section runs through these
# helpers so freezes are bounded + observable.
#
# Enable startup tracing:
#   INSTALL_DOCTOR_ZSHRC_DEBUG=1 zsh -i
#   ⇒ writes per-section START/END + duration to
#     ~/.local/state/zsh/startup-<pid>.log
#
# Tighten the per-call timeout (default 3 s):
#   INSTALL_DOCTOR_ZSHRC_TIMEOUT=1 zsh -i
#
# Panic key — Ctrl-Alt-X anywhere on the prompt force-reloads zsh in case
# something does manage to lock up. Bound below after p10k loads.
# ============================================================================
zmodload zsh/datetime 2>/dev/null
zmodload zsh/parameter 2>/dev/null

### _id_log <text> — append a timestamped line to the debug log. No-op
### unless INSTALL_DOCTOR_ZSHRC_DEBUG=1.
_id_log() {
  [[ -z ${INSTALL_DOCTOR_ZSHRC_DEBUG:-} ]] && return 0
  local lf="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/startup-$$.log"
  [[ -d ${lf:h} ]] || mkdir -p ${lf:h} 2>/dev/null
  printf '[%s] %s\n' "${EPOCHREALTIME}" "$*" >> "$lf" 2>/dev/null
}

### _id_section <name> <code…> — run <code> wrapped in START/END log lines
### plus duration. Always returns the inner block's exit code.
_id_section() {
  local _id_n="$1"; shift
  _id_log "START ${_id_n}"
  local _id_t0=${EPOCHREALTIME:-0}
  "$@"
  local _id_rc=$?
  local _id_ms=$(( (${EPOCHREALTIME:-0} - _id_t0) * 1000 ))
  _id_log "END   ${_id_n} rc=${_id_rc} ${_id_ms%.*}ms"
  return $_id_rc
}

### _id_safe <name> <cmd…> — run <cmd> with a hard timeout (default 3 s,
### override via INSTALL_DOCTOR_ZSHRC_TIMEOUT). On timeout, the call is
### killed and a FAIL line is logged so the user can see which section
### hung. Errors are suppressed so nothing in this rc file can bubble.
_id_safe() {
  local _id_n="$1"; shift
  local _id_to="${INSTALL_DOCTOR_ZSHRC_TIMEOUT:-3}"
  local _id_rc=0
  ### gtimeout (coreutils) preferred — sends SIGTERM then SIGKILL after 1s.
  ### Falls back to bare exec if neither timeout binary exists; we'd
  ### rather run-without-timeout than refuse to source the user's tools.
  if (( $+commands[gtimeout] )); then
    gtimeout --kill-after=1 "$_id_to" "$@" 2>/dev/null
    _id_rc=$?
  elif (( $+commands[timeout] )); then
    timeout --kill-after=1 "$_id_to" "$@" 2>/dev/null
    _id_rc=$?
  else
    "$@" 2>/dev/null
    _id_rc=$?
  fi
  if (( _id_rc != 0 )); then
    _id_log "FAIL  ${_id_n} rc=${_id_rc} timeout=${_id_to}s cmd='$*'"
  fi
  return $_id_rc
}

### _id_source_safe <name> <file> — source a file iff readable, with an
### optional pre-source existence check + a logged failure on parse error.
_id_source_safe() {
  local _id_n="$1" _id_f="$2"
  [[ -r "$_id_f" ]] || { _id_log "SKIP  ${_id_n} (file missing: $_id_f)"; return 0; }
  _id_log "SRC   ${_id_n} ($_id_f)"
  local _id_t0=${EPOCHREALTIME:-0}
  source "$_id_f" 2>/dev/null
  local _id_rc=$?
  local _id_ms=$(( (${EPOCHREALTIME:-0} - _id_t0) * 1000 ))
  if (( _id_rc != 0 )); then
    _id_log "FAIL  ${_id_n} rc=${_id_rc} ${_id_ms%.*}ms"
  else
    _id_log "DONE  ${_id_n} ${_id_ms%.*}ms"
  fi
  return 0
}

### _id_eval_safe <name> <command-that-prints-zsh> — equivalent to
### eval "$(cmd init zsh)" but with timeout + duration logging. Used for
### atuin/direnv/mise/zoxide-style init eval blocks so a hung daemon (or
### a binary that prints a 7KB blob slowly) can never freeze the shell.
_id_eval_safe() {
  local _id_n="$1"; shift
  local _id_to="${INSTALL_DOCTOR_ZSHRC_TIMEOUT:-3}"
  local _id_out _id_rc
  _id_log "EVAL  ${_id_n} (timeout=${_id_to}s)"
  local _id_t0=${EPOCHREALTIME:-0}
  if (( $+commands[gtimeout] )); then
    _id_out=$(gtimeout --kill-after=1 "$_id_to" "$@" 2>/dev/null)
  elif (( $+commands[timeout] )); then
    _id_out=$(timeout --kill-after=1 "$_id_to" "$@" 2>/dev/null)
  else
    _id_out=$("$@" 2>/dev/null)
  fi
  _id_rc=$?
  local _id_ms=$(( (${EPOCHREALTIME:-0} - _id_t0) * 1000 ))
  if (( _id_rc != 0 )) || [[ -z "$_id_out" ]]; then
    _id_log "FAIL  ${_id_n} rc=${_id_rc} ${_id_ms%.*}ms (no output)"
    return $_id_rc
  fi
  ### Re-eval in the calling shell context so hook installs land
  eval "$_id_out" 2>/dev/null
  local _id_evrc=$?
  if (( _id_evrc != 0 )); then
    _id_log "FAIL  ${_id_n} eval-rc=${_id_evrc} ${_id_ms%.*}ms"
  else
    _id_log "DONE  ${_id_n} ${_id_ms%.*}ms"
  fi
  return $_id_evrc
}

_id_log "----- shell start -----"
_id_log "ZSH_VERSION=$ZSH_VERSION TERM_PROGRAM=${TERM_PROGRAM:-} TTY=$([[ -t 0 ]] && print -- yes || print -- no)"
export HISTSIZE=100000
export SAVEHIST=100000
export ZLE_RPROMPT_INDENT=1
export WORDCHARS=${WORDCHARS//\/}
export PROMPT_EOL_MARK=
export TIMEFMT=$'\nreal\t%E\nuser\t%U\nsys\t%S\ncpu\t%P'

### Job control. `setopt monitor` only succeeds when zsh has a controlling
### TTY (i.e. a real terminal). When invoked as a subprocess (Claude Code's
### `zsh -i -c`, headless `script`, IDE-embedded shells), the option can't
### be set and zsh prints `(anon):setopt:7: can't change option: monitor`.
### Trying-and-suppressing keeps job control alive in real terminals AND
### silences the message everywhere else. Also needed by powerlevel10k's
### gitstatusd which spawns its daemon via job control — without this the
### "[ERROR]: gitstatus failed to initialize" + "Restart Zsh to retry" wall
### of text fires on every shell launch when there's no controlling TTY.
setopt monitor 2>/dev/null || true

### `POWERLEVEL9K_INSTANT_PROMPT=quiet` silences p10k's instant-prompt
### console-output warnings (e.g. when zinit prints during plugin clones,
### when gitstatusd can't init, when a sourced rcfile echoes). Without
### this, the user opens Terminal/Warp and sees a 10-line p10k diagnostic
### blob ABOVE the prompt — which IS the prompt-blocking behavior we're
### fixing. `quiet` keeps instant-prompt fully functional; it just hushes
### the diagnostic stream.
typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet

### When zsh is invoked without a controlling TTY (Claude Code's
### `zsh -i -c`, headless `script` runs, IDE-embedded shells), p10k's
### gitstatusd daemon can't spawn (it needs job control which requires a
### TTY) and prints "ERROR: gitstatus failed to initialize" + "Restart
### Zsh to retry" — that's the wall-of-text Brian sees when Claude Code
### opens a subprocess to run a command. Disable gitstatus entirely in
### that context; real terminal launches (stdin connected to a TTY) keep
### the full git-status segment.
[[ -t 0 ]] || POWERLEVEL9K_DISABLE_GITSTATUS=true

### Powerlevel10k instant prompt MUST come before any console output
### (echo, print, p10k themselves before this line, ...) — otherwise p10k
### prints a warning and disables the cached prompt for this session.
[[ ! -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]] || source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"

### .zcompdump location — bumped per zsh version so a zsh upgrade rebuilds
### automatically instead of using a stale dump
export ZSH_COMPDUMP="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-$ZSH_VERSION"
[ -d "${XDG_CACHE_HOME:-$HOME/.cache}/zsh" ] || mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}/zsh"

# ---------------------------------------------------------------------------
# Settings + key bindings
# ---------------------------------------------------------------------------
setopt AUTO_CD BEEP CORRECT HIST_BEEP HIST_EXPIRE_DUPS_FIRST HIST_FIND_NO_DUPS \
       HIST_IGNORE_ALL_DUPS HIST_IGNORE_DUPS HIST_REDUCE_BLANKS HIST_SAVE_NO_DUPS \
       HIST_VERIFY INC_APPEND_HISTORY INTERACTIVE_COMMENTS MAGIC_EQUAL_SUBST \
       NO_NO_MATCH NOTIFY NUMERIC_GLOB_SORT PROMPT_SUBST SHARE_HISTORY

zstyle ':completion:*:*:*:*:*' menu select
zstyle ':completion:*' cache-path "${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompcache"
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' auto-description 'specify: %d'
zstyle ':completion:*' completer _expand _complete
zstyle ':completion:*' format 'Completing %d'
zstyle ':completion:*' group-name ''
zstyle ':completion:*' list-prompt %SAt %p: Hit TAB for more, or the character to insert%s
zstyle ':completion:*' rehash true
zstyle ':completion:*' select-prompt %SScrolling active: current selection at %p%s
zstyle ':completion:*' use-compctl false
zstyle ':completion:*' verbose true
# shellcheck disable=SC2016
zstyle ':completion:*:kill:*' command 'ps -u $USER -o pid,%cpu,tty,cputime,cmd'
zstyle ':completion:*:git-checkout:*' sort false
zstyle ':completion:*:descriptions' format '[%d]'

### fzf-tab + eza preview for `cd` completion (only when both installed)
if command -v fzf > /dev/null && command -v eza > /dev/null; then
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
  zstyle ':fzf-tab:*' switch-group ',' '.'
fi

bindkey -e
bindkey '^U' backward-kill-line
bindkey '^[[2~' overwrite-mode
bindkey '^[[3~' delete-char
bindkey '^[[H'  beginning-of-line
bindkey '^[[1~' beginning-of-line
bindkey '^[[F'  end-of-line
bindkey '^[[4~' end-of-line
bindkey '^[[1;5C' forward-word
bindkey '^[[1;5D' backward-word
bindkey '^[[3;5~' kill-word
bindkey '^[[5~'  beginning-of-buffer-or-history
bindkey '^[[6~'  end-of-buffer-or-history
bindkey '^[[Z'  undo
bindkey ' '    magic-space

### Homebrew completion FPATH — populated BEFORE compinit so brew formula
### completions are picked up
if [ -n "$HOMEBREW_PREFIX" ]; then
  [ -d "$HOMEBREW_PREFIX/share/zsh/site-functions" ] && export FPATH="$HOMEBREW_PREFIX/share/zsh/site-functions:$FPATH"
  [ -d "$HOMEBREW_PREFIX/share/zsh-completions" ] && export FPATH="$HOMEBREW_PREFIX/share/zsh-completions:$FPATH"
fi
[ -d "${XDG_DATA_HOME:-$HOME/.local/share}/zsh-completion" ] && export FPATH="${XDG_DATA_HOME:-$HOME/.local/share}/zsh-completion:$FPATH"

# ---------------------------------------------------------------------------
# zinit — turbo-mode plugin manager
# ---------------------------------------------------------------------------
### Bootstrap zinit if missing. Single git clone; only happens once on a
### fresh machine. After that the chezmoi-managed `~/.local/share/zinit`
### is reused.
export ZINIT_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
if [ ! -f "$ZINIT_HOME/zinit.zsh" ]; then
  mkdir -p "${ZINIT_HOME:h}"
  command git clone --depth 1 https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME" 2>/dev/null
fi
source "$ZINIT_HOME/zinit.zsh"

# ---------------------------------------------------------------------------
# Powerlevel10k — synchronous (it IS the prompt; instant-prompt already
# painted the cached version above)
# ---------------------------------------------------------------------------
zinit ice depth=1
zinit light romkatv/powerlevel10k

### p10k visual config — sourced from chezmoi-managed file. If absent we
### fall back to the legacy inline POWERLEVEL9K_* settings preserved in
### profile.sh, so the prompt is never broken.
[ ! -f "${XDG_CONFIG_HOME:-$HOME/.config}/shell/p10k.zsh" ] || source "${XDG_CONFIG_HOME:-$HOME/.config}/shell/p10k.zsh"

# ---------------------------------------------------------------------------
# Deferred plugins — every line below loads 0ms AFTER the first prompt
# renders. Slowness here is invisible to the user.
#
# Ordering of `wait'<N><letter>'` matters:
#   - Same N = same wait batch
#   - Letter (a/b/c…) = sequence within a batch
#   - zsh-syntax-highlighting MUST be last (it hooks ZLE), so it gets the
#     latest wait + atinit'zicompinit; zicdreplay' to finalize compinit.
# ---------------------------------------------------------------------------

### Syntax highlighting + autosuggestions + extra completions + fzf-tab.
###
### `zicompinit` is the correct zinit function (an earlier draft used
### `zicompinit_fast` which does not exist and produced
### "ERROR The 'zicompinit_fast' command was not found and could not be
### loaded." on every shell launch). `zicompinit; zicdreplay` runs the
### real `compinit` once + replays any pending `compdef` calls.
zinit wait'0a' lucid light-mode for \
  atinit"zicompinit; zicdreplay" \
    zdharma-continuum/fast-syntax-highlighting \
  atload"_zsh_autosuggest_start" \
    zsh-users/zsh-autosuggestions \
  blockf atpull'zinit creinstall -q .' \
    zsh-users/zsh-completions \
  aloxaf/fzf-tab
### REMOVED 2026-06-09: marlonrichert/zsh-autocomplete. The plugin
### auto-completes inline as the user types — it runs `compgen` on every
### keystroke. Combined with fzf-tab (TAB-driven menu) + zsh-autosuggestions
### (async ghost text) + fast-syntax-highlighting (re-highlights on buffer
### change), the four plugins together caused visible flicker, delayed
### keystrokes, and prompt redraws that read as "the terminal messes up
### after a few commands". fzf-tab + autosuggestions already cover the
### completion UX without the per-keystroke cost. To re-enable, add the
### line back AND set `zstyle ':autocomplete:*' min-input 3` so it only
### fires after 3 chars typed (kills the per-keystroke spike).

### Oh-My-Zsh plugin snippets — only the ones whose underlying tool is
### actually installed or whose pure-zsh helper has lasting value
zinit wait'0b' lucid for \
  OMZP::command-not-found \
  OMZP::copybuffer \
  OMZP::encode64 \
  OMZP::sudo \
  OMZP::safe-paste \
  OMZP::last-working-dir \
  OMZP::timer \
  OMZP::urltools \
  OMZP::web-search \
  OMZP::zsh-interactive-cd \
  OMZP::zsh-navigation-tools

### Git plugins — Brian uses these daily.
###
### Removed (do not re-add): OMZP::git-flow + OMZP::gitfast. Both are
### multi-file OMZ plugins (they `source` sibling files like `_git-flow`
### and `git-prompt.sh`). zinit's `OMZP::` shorthand only downloads the
### entry point — sibling files 404 — and the `svn` ice that fetches
### the whole subdirectory requires Subversion which Apple removed from
### macOS 10.14+. Net loss is small: brew's git ships full completion
### via FPATH (so `gitfast` is redundant) and `git flow` completion is
### niche enough to re-add per-machine if actually used.
zinit wait'0c' lucid for \
  OMZP::git-extras \
  OMZP::git-auto-fetch \
  OMZP::github

### Tool-specific plugins — gated on tool presence so an uninstalled
### tool doesn't drag in dead completion definitions.
###
### Removed (do not re-add):
###   - OMZP::node-docs — never existed in ohmyzsh/ohmyzsh (404)
###   - OMZP::ripgrep   — never existed (ripgrep ships its own FPATH
###                        completion from brew)
###   - OMZP::macos     — multi-file plugin (sources `music`/`spotify`
###                        sibling files); same svn-required issue as
###                        gitfast/git-flow. Niche aliases (`cdf`,
###                        `quick-look`, `tab`) can be added inline if
###                        wanted.
(( $+commands[docker] ))   && zinit wait'0d' lucid for OMZP::docker OMZP::docker-compose
(( $+commands[kubectl] ))  && zinit wait'0d' lucid for OMZP::kubectx
(( $+commands[terraform] )) && zinit wait'0d' lucid for OMZP::terraform
(( $+commands[go] ))       && zinit wait'0d' lucid for OMZP::golang
(( $+commands[yarn] ))     && zinit wait'0d' lucid for OMZP::yarn

# ---------------------------------------------------------------------------
# compinit — cached. Rebuilds the dump at most once per day instead of on
# every shell launch (saves 50-100ms warm).
# ---------------------------------------------------------------------------
autoload -Uz compinit
{
  local _zcd="$ZSH_COMPDUMP"
  if [[ ! -e "$_zcd" || -n "$(find "$_zcd" -mtime +1 2>/dev/null)" ]]; then
    compinit -d "$_zcd"
  else
    compinit -C -d "$_zcd"
  fi
}
### bashcompinit is slow (~20ms) and only matters when bash-completion
### files exist. Skip entirely if neither the bash_completion.sh nor any
### bash-style completion file is present.
if [ -f "/usr/local/etc/profile.d/bash_completion.sh" ] || [ -f "$HOMEBREW_PREFIX/etc/profile.d/bash_completion.sh" ]; then
  autoload -Uz bashcompinit && bashcompinit
  [ -f "$HOMEBREW_PREFIX/etc/profile.d/bash_completion.sh" ] && source "$HOMEBREW_PREFIX/etc/profile.d/bash_completion.sh"
  [ -f "/usr/local/etc/profile.d/bash_completion.sh" ] && source "/usr/local/etc/profile.d/bash_completion.sh"
fi

# ---------------------------------------------------------------------------
# Lazy stubs for eval-init tools.
#
# Each stub: declares a function with the tool's name that, on first call,
# unsets itself, runs the real `eval "$(tool init zsh)"`, then forwards
# the original args. Net cost when the tool is never invoked: 0 ms.
# ---------------------------------------------------------------------------
_id_lazy() {
  ### $1 = command name, $2 = eval-producing subcommand (e.g. "init zsh")
  ### Lazy stubs are cheap — defining the function is microseconds — but
  ### the FIRST CALL evals the tool's init blob. Wrapped via _id_eval_safe
  ### so a hung daemon (mise polling, direnv binary missing) can never
  ### freeze the shell once the user triggers it.
  local cmd="$1" init="$2"
  command -v "$cmd" >/dev/null 2>&1 || { _id_log "SKIP  lazy-$cmd (not on PATH)"; return 0; }
  eval "$cmd() { unfunction $cmd; _id_eval_safe lazy-$cmd command $cmd $init; $cmd \"\$@\"; }"
  _id_log "STUB  lazy-$cmd"
}
### Tools the user invokes directly (lazy-stubbed; init on first call):
_id_lazy direnv      'hook zsh'
_id_lazy mise        'activate zsh'
_id_lazy rtx         'activate zsh'
_id_lazy navi        'widget zsh'
_id_lazy ntfy        'shell-integration'
_id_lazy pay-respects 'zsh --alias'
_id_lazy zoxide      'init zsh'
_id_lazy sheldon     'source'
unfunction _id_lazy

### atuin — defer init to first precmd hook (runs AFTER prompt renders, ~50ms
### invisible to user). The eval is timeout-wrapped via _id_eval_safe so a
### stuck atuin daemon / locked SQLite DB can never freeze the shell.
### After atuin's init installs ITS OWN precmd hook (_atuin_precmd writes
### the previous command to the DB), we re-wrap that hook with a 200ms
### timeout via _id_atuin_precmd_guard — a stuck DB write would otherwise
### freeze EVERY prompt forever.
if command -v atuin > /dev/null; then
  _id_defer_atuin() {
    add-zsh-hook -d precmd _id_defer_atuin
    _id_eval_safe atuin-init command atuin init zsh --disable-up-arrow
    ### Wrap atuin's installed _atuin_precmd to run in a backgrounded
    ### parens-subshell. `( cmd ) &!` is a single fork — no `zsh -c`
    ### overhead — and the subshell inherits the parent's variables
    ### (including $?, $HISTFILE, etc.) which atuin needs to record the
    ### previous command. `&!` disowns immediately so the prompt loop
    ### never waits on it. If atuin's DB is locked the background
    ### subshell hangs harmlessly; the user never sees it.
    if typeset -f _atuin_precmd > /dev/null; then
      functions[_atuin_precmd_unsafe]=$functions[_atuin_precmd]
      _atuin_precmd() { ( _atuin_precmd_unsafe 2>/dev/null ) &! }
      _id_log "GUARD _atuin_precmd wrapped (parens-subshell, &!-disowned)"
    fi
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _id_defer_atuin
fi

### fzf — defer key-bindings + completion to precmd hook so they load
### AFTER first prompt renders. Ctrl-T (file picker) and Alt-C (cd
### picker) become available within ~10ms of the prompt appearing.
### fzf-tab (TAB completion menus, different layer) is already loaded
### via zinit turbo above.
if [ -f "${HOMEBREW_PREFIX:-/opt/homebrew}/opt/fzf/shell/key-bindings.zsh" ]; then
  _id_defer_fzf() {
    add-zsh-hook -d precmd _id_defer_fzf
    _id_source_safe fzf-keys      "${HOMEBREW_PREFIX:-/opt/homebrew}/opt/fzf/shell/key-bindings.zsh"
    _id_source_safe fzf-completion "${HOMEBREW_PREFIX:-/opt/homebrew}/opt/fzf/shell/completion.zsh"
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _id_defer_fzf
fi

### zoxide alias fallback — when zoxide isn't installed, keep `z` as a
### `cd` shortcut so muscle memory doesn't break
command -v zoxide >/dev/null 2>&1 || alias z='cd'

### Carapace + cod — defer to a precmd hook + timeout-wrap the carapace
### init (which can take 500ms+ on cold cache). cod is wrapped the same
### way. Both source via process-substitution — if either binary hangs
### the source would hang the shell, so we capture-then-eval through
### _id_eval_safe which kills the producer after 3s.
_id_defer_completions() {
  add-zsh-hook -d precmd _id_defer_completions
  if command -v carapace > /dev/null; then
    zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'
    zstyle ':completion:*:git:*' group-order 'main commands' 'alias commands' 'external commands'
    _id_eval_safe carapace command carapace _carapace
  fi
  command -v cod >/dev/null 2>&1 && _id_eval_safe cod command cod init $$ zsh
}
autoload -Uz add-zsh-hook
add-zsh-hook precmd _id_defer_completions

# ---------------------------------------------------------------------------
# Tools without a `(tool) init zsh` story — sourced from cached files
# ---------------------------------------------------------------------------

### Google Cloud SDK — fleet-aware PATH + completion sourcing. Probe every
### install location used across our supported OSes (macOS Homebrew cask,
### apt-installed deb on Ubuntu/Debian, dnf-installed rpm on Fedora, snap
### on Ubuntu, manual tarball under /opt/google-cloud-sdk, user-local
### install under ~/google-cloud-sdk). First hit wins; subsequent paths
### are skipped. Every source call now goes through _id_source_safe so a
### corrupt completion file can never freeze the prompt.
for _gcloud_root in \
  "$HOMEBREW_PREFIX/share/google-cloud-sdk" \
  /usr/lib/google-cloud-sdk \
  /usr/share/google-cloud-sdk \
  /opt/google-cloud-sdk \
  /snap/google-cloud-sdk/current \
  "$HOME/google-cloud-sdk"; do
  if [ -f "$_gcloud_root/path.zsh.inc" ]; then
    _id_source_safe gcloud-path       "$_gcloud_root/path.zsh.inc"
    _id_source_safe gcloud-completion "$_gcloud_root/completion.zsh.inc"
    break
  fi
done
unset _gcloud_root

### Goto — must `unalias` first; oh-my-zsh + several dotfile templates
### ship a `goto` alias that breaks the function definition
if [ -f "${XDG_CONFIG_HOME:-$HOME/.config}/shell/goto.sh" ]; then
  unalias goto 2>/dev/null
  builtin setopt no_aliases 2>/dev/null
  _id_source_safe goto "${XDG_CONFIG_HOME:-$HOME/.config}/shell/goto.sh"
  builtin setopt aliases 2>/dev/null
fi

### hiSHtory
export PATH="$PATH:${XDG_CONFIG_HOME:-$HOME/.config}/hishtory"
_id_source_safe hishtory "${XDG_CONFIG_HOME:-$HOME/.config}/hishtory/config.zsh"

### Hoard
if command -v hoard > /dev/null; then
  _id_source_safe hoard "${XDG_DATA_HOME:-$HOME/.local/share}/hoard/src/shell/hoard.zsh"
fi

### iTerm2
_id_source_safe iterm2 "${XDG_CONFIG_HOME:-$HOME/.config}/shell/iterm/iterm2.zsh"

### Up — directory traversal helper
_id_source_safe up "${XDG_DATA_HOME:-$HOME/.local/share}/up/up.sh"

### HashiCorp Vault
command -v vault > /dev/null && complete -o nospace -C vault vault

### Autocomplete UX tuning — applies to marlonrichert/zsh-autocomplete
zstyle ':autocomplete:*' list-lines 14
zstyle ':autocomplete:history-search:*' list-lines 14
zstyle ':autocomplete:history-incremental-search-*:*' list-lines 14
command -v fzf > /dev/null && zstyle ':autocomplete:*' fzf-completion yes
command -v zoxide > /dev/null && zstyle ':autocomplete:recent-dirs' backend zoxide

# ---------------------------------------------------------------------------
# Optional: custom command_not_found_handler
