if [[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/shell/not-found-hook.sh" ]]; then
  source "${XDG_CONFIG_HOME:-$HOME/.config}/shell/not-found-hook.sh"
  command_not_found_handler() { handle_command_not_found "$1"; }
