# ---------------------------------------------------------------------------
# Terminal title + tool-specific hooks
# ---------------------------------------------------------------------------
case "$TERM" in
xterm*|rxvt*|Eterm|aterm|kterm|gnome*|alacritty)
  precmd() { print -Pnr -- $'\e]0;%n@%m: %~\a'; }
  ;;
esac

### Warp Terminal integration is AUTO-DETECTED from the WARP_IS_LOCAL_SHELL_SESSION /
### TERM_PROGRAM=WarpTerminal env vars Warp injects itself. Don't emit a manual
### `SourcedRcFileForWarp` DCS hook — when both Warp's auto-integration AND a
### manual hook fire, Warp's second injection lands as a malformed heredoc:
### the user sees a 50-line block of `function warp_complete_via_compadd_…`
### printed to the terminal followed by an orphan `EOM` and `heredoc>` prompts.
### Removed 2026-05-24 after that exact symptom was reported. If you ever need
### to force-resync Warp's integration, run `warp shell rcfile-bootstrap`
### manually instead of putting it in dot_zshrc.

### Toggle p10k 1-line ↔ 2-line prompt with Ctrl-P (kept from legacy
### config; bound to the same key)
switch_powerlevel_multiline_prompt() {
  [ "$POWERLEVEL9K_PROMPT_ON_NEWLINE" = true ] \
    && POWERLEVEL9K_PROMPT_ON_NEWLINE=false \
    || POWERLEVEL9K_PROMPT_ON_NEWLINE=true
  zle && zle accept-line
}
zle -N switch_powerlevel_multiline_prompt
bindkey ^P switch_powerlevel_multiline_prompt

### Per-prompt timing tap. When INSTALL_DOCTOR_ZSHRC_DEBUG=1, every
### preexec records when the command started and every precmd records
### how long the prompt-redraw cycle took. If any prompt cycle exceeds
### 100ms, the log gets a SLOW line naming the previous command. After
### one interactive session the user can `grep SLOW
### ~/.local/state/zsh/startup-*.log` to find the culprit.
if [[ -n ${INSTALL_DOCTOR_ZSHRC_DEBUG:-} ]]; then
  _id_preexec() {
    typeset -g _id_last_cmd_start=${EPOCHREALTIME:-0}
    typeset -g _id_last_cmd_body="$1"
  }
  _id_precmd() {
    local _id_now=${EPOCHREALTIME:-0}
    local _id_dur_ms=$(( (_id_now - ${_id_last_cmd_start:-_id_now}) * 1000 ))
    if (( _id_dur_ms > 100 )); then
      _id_log "SLOW  precmd cycle ${_id_dur_ms%.*}ms after cmd: '${_id_last_cmd_body:0:60}'"
    else
      _id_log "PROMPT ${_id_dur_ms%.*}ms (cmd: '${_id_last_cmd_body:0:40}')"
    fi
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook preexec _id_preexec
  add-zsh-hook precmd _id_precmd
fi

### Panic key — Ctrl-Alt-X anywhere force-reloads zsh in case anything
### ever does manage to lock up. Single keypress recovery without having
### to kill the terminal.
_id_panic_reload() {
  _id_log "PANIC reload triggered via Ctrl-Alt-X"
  zle -I
  exec zsh
}
zle -N _id_panic_reload
bindkey '^[^X' _id_panic_reload

### Mark end of rcfile — if the user reports a freeze and the log shows
### "rcfile DONE" before the freeze, the issue is in a precmd / preexec
### hook (most likely atuin / carapace / cod / fzf-deferred init). If the
### log stops BEFORE "rcfile DONE", the freeze is during shell init.
_id_log "rcfile DONE"
